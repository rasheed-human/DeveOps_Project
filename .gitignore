# ============================================================
# .gitignore — Kubernetes GitOps Project
# ============================================================

# CRITICAL: Never commit plaintext secrets
*.env
.env.*
!.env.example
**/secret.yaml
!**/*sealed*secret*.yaml   # SealedSecrets are safe to commit

# Temporary kubeseal files
/tmp/
*.pem
*-key.json
serviceaccount.json
credentials.json

# Local cluster configs
kubeconfig
kubeconfig-*
*.kubeconfig

# Helm
charts/*.tgz
.helm/

# Kustomize build output (never commit these)
kustomize-output/
*.rendered.yaml

# Node.js
node_modules/
npm-debug.log*
.npm/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Build artifacts
dist/
build/
*.tar.gz
*.zip

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Test coverage
coverage/
.nyc_output/

# Terraform (if used for cluster provisioning)
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars
!*.tfvars.example

# ArgoCD generated files (managed by ArgoCD, not committed)
# Exception: application definitions ARE committed
